{
  "name": "endb-backend",
  "version": "1.0.0",
  "description": "English vocabulary management API using Cloudflare Workers",
  "main": "src/index.ts",
  "packageManager": "pnpm@10.23.0+sha512.21c4e5698002ade97e4efe8b8b4a89a8de3c85a37919f957e7a0f30f38fbc5bbdd05980ffe29179b2fb6e6e691242e098d945d1601772cad0fef5fb6411e2a4b",
  "scripts": {
    "dev": "wrangler dev --log-level debug",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute endb --file=./migrations/0001_initial.sql",
    "db:migrate:local": "wrangler d1 execute endb --local --file=./migrations/0001_initial.sql"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "d1",
    "vocabulary"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.50.0"
  }
}
